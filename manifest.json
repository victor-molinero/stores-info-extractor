{
  "manifest_version": 3,
  "name": "Stores Info Extractor",
  "version": "1.0.0",
  "description": "Extract purchase information from Amazon and Walmart pages with selectable extraction modes.",
  "permissions": ["activeTab", "downloads", "storage", "sidePanel"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com.mx/*",
        "https://www.amazon.com/*",
        "https://www.walmart.com.mx/lists",
        "https://www.walmart.com.mx/lists/*",
        "https://www.walmart.com.mx/cart",
        "https://www.walmart.com.mx/cart/*"
      ],
      "js": ["content.js"]
    }
  ]
}
